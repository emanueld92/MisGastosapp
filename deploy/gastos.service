[Unit]
Description=Gastos Sync (FastAPI)
After=network.target

[Service]
WorkingDirectory=/opt/gastos/server
Environment=GASTOS_TOKEN=CAMBIA-ESTE-TOKEN
Environment=GASTOS_DB=/var/lib/gastos/gastos.db
ExecStart=/opt/gastos/server/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
